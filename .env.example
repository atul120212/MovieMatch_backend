# ─────────────────────────────────────────────
# MovieMatch — Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# SQLite (default – works out of the box, no setup needed)
# DATABASE_URL=sqlite:///./moviematch.db
# postgresql://postgres.jnszppsqwibkrsiesezj:~OA[`+mADAJ1EVjs@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
# PostgreSQL / Supabase (uncomment and fill to switch)
DATABASE_URL='postgresql://postgres.jnszppsqwibkrsiesezj:~OA[`+mADAJ1EVjs@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres'

# TMDB API key (https://www.themoviedb.org/settings/api)
# Leave empty to use the built-in 50-movie mock database
TMDB_API_KEY=7344cceeaeda07b18921aa3829f04e9e

# Session expiry in hours (default: 24)
SESSION_EXPIRY_HOURS=24
